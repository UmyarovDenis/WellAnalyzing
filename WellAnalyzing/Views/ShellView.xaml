<Window x:Class="WellAnalyzing.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WellAnalyzing.Views"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="WhiteSmoke"
        Title="Сводные значения по скважинам" Height="750" Width="650">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition/>
            <RowDefinition MaxHeight="200"/>
        </Grid.RowDefinitions>
        <Menu Background="White">
            <MenuItem Header="Файл" Height="28">
                <MenuItem Header="Импорт данных"
                          Command="{Binding ImportRawDataCommand}"/>
                <MenuItem Header="Экспорт данных"
                          Command="{Binding ExportJsonDataCommand}"/>
            </MenuItem>
        </Menu>
        <Separator Grid.Row="1"/>
        <Border Grid.Row="2" Background="White">
            <Grid Margin="10">
                <DataGrid x:Name="WellsDataGrid"
                          ItemsSource="{Binding WellSummaries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FFE0E0E0"
                          Background="White"
                          BorderBrush="#FFCCCCCC"
                          BorderThickness="1"
                          AlternatingRowBackground="#FFF9F9F9"
                          AlternationCount="2"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" 
                                            Width="50"
                                            Binding="{Binding WellId}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="5,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Позиционирование" 
                                            Width="130"
                                            Binding="{Binding Position}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="5,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Общая глубина, м" 
                                            Width="120"
                                            Binding="{Binding TotalDepth, StringFormat={}{0:F2}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="5,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Интервалы" 
                                            Width="80"
                                            Binding="{Binding IntervalCount}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="5,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Пористость" 
                                            Width="100"
                                            Binding="{Binding PorosityAverage, StringFormat={}{0:F3}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="5,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Порода" 
                                            Width="*"
                                            Binding="{Binding Rock}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="5,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="White">
            <Grid>
                <ListView ItemsSource="{Binding ValidationErrors}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Ошибка: "
                                               Foreground="Red"
                                               FontSize="14"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding}"
                                               FontSize="14"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
